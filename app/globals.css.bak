@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg-main: #F8FAFC;
  --bg-card: #FFFFFF;
  --bg-alt: #F1F5F9;
  --primary: #1D4ED8;
  --primary-dark: #1E40AF;
  --primary-light: #3B82F6;
  --text-primary: #0F172A;
  --text-secondary: #64748B;
  --success: #16A34A;
  --success-bg: #F0FDF4;
  --danger: #DC2626;
  --danger-bg: #FEF2F2;
  --warning: #D97706;
  --warning-bg: #FFFBEB;
  --info: #0EA5E9;
  --info-bg: #F0F9FF;
  --slot-free: #16A34A;
  --slot-free-bg: #F0FDF4;
  --slot-occupied: #DC2626;
  --slot-occupied-bg: #FEF2F2;
  --slot-past: #94A3B8;
  --slot-past-bg: #F8FAFC;
  --seed-bg: #FEF3C7;
  --seed-text: #92400E;
  --seed-border: #F59E0B;
  --border: #E2E8F0;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  font-family: var(--font-poppins, 'Inter'), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

body {
  background-color: var(--bg-main);
  color: var(--text-primary);
  font-family: var(--font-poppins, 'Inter'), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1, h2, h3 {
  font-weight: 700;
  font-family: var(--font-playfair, 'Inter'), -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

h1 {
  font-size: 4rem;
  letter-spacing: -0.02em;
}

@media (max-width: 768px) {
  h1 {
    font-size: 2.5rem;
  }
}

::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(168, 85, 247, 0.5);
  border-radius: 4px;
}
